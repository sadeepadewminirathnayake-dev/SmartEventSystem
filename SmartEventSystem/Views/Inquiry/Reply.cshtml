@model SmartEventSystem.Models.Inquiry

<div class="container mt-5">
    <div class="card p-4 shadow">
        <h4 class="mb-3">Reply to Inquiry</h4>

        <p><strong>Guest:</strong> @Model.GuestName</p>
        <p><strong>Email:</strong> @Model.Email</p>
        <p><strong>Message:</strong> @Model.Message</p>
        <p><strong>Date:</strong> @Model.InquiryDate.ToShortDateString()</p>

        <form asp-action="Reply" method="post">
            <input type="hidden" asp-for="InquiryID" />

            <div class="mb-3">
                <label class="form-label">Your Reply</label>
                <textarea asp-for="Reply"
                          class="form-control"
                          rows="4"
                          required></textarea>
            </div>

            <button type="submit" class="btn btn-success">
                Send Reply
            </button>
        </form>
    </div>
</div>
