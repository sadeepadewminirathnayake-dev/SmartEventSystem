@model SmartEventSystem.Models.Event

<div class="container mt-5">

    <div class="card shadow-lg border-0 rounded-4">

        <div class="card-body p-5">

            <h2 class="text-center text-primary fw-bold mb-4">
                @Model.EventName
            </h2>



            <div class="row">

                <div class="col-md-6">
                    <p class="mb-3">
                        <strong>Date:</strong>
                        @Model.EventDate.ToShortDateString()
                    </p>

                    <p class="mb-3">
                        <strong>Time:</strong>
                        @Model.EventTime
                    </p>

                    <p>
                        <strong>Description:</strong>
                    </p>
                    <p class="text-muted">
                        @Model.Description
                    </p>


                    <p class="mb-3 fs-5">
                        <strong>Price:</strong>
                        <span class="badge bg-success fs-6">
                            Rs. @Model.Price
                        </span>
                    </p>

                  
                </div>

                <div class="col-md-6">
                   
                </div>

            </div>

            <hr class="my-4" />

            <!-- ACTION BUTTONS -->
            <div class="d-flex flex-wrap gap-3 justify-content-center">

                <a asp-controller="Booking"
                   asp-action="Create"
                   asp-route-eventId="@Model.EventID"
                   class="btn btn-success btn-lg action-btn">
                    🎟 Book Ticket
                </a>

                <a asp-controller="Review"
                   asp-action="Create"
                   asp-route-eventId="@Model.EventID"
                   class="btn btn-primary btn-lg action-btn">
                    ✍ Write Review
                </a>

                <a asp-controller="Review"
                   asp-action="Browse"
                   asp-route-eventId="@Model.EventID"
                   class="btn btn-info btn-lg action-btn">
                    👀 View Reviews
                </a>



                <a asp-action="Browse"
                   class="btn btn-secondary btn-lg action-btn">
                    ⬅ Back
                </a>

            </div>

        </div>

    </div>

</div>

<style>
    .action-btn {
        transition: all 0.3s ease;
        border-radius: 10px;
    }

        .action-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.2);
        }
</style>

