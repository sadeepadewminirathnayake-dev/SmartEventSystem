@model SmartEventSystem.Models.Event

@{
    ViewData["Title"] = "Delete Event";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="text-center mb-4">
                <i class="fas fa-exclamation-triangle text-danger fa-3x mb-3"></i>
                <h2 class="fw-bold">Delete Event?</h2>
                <p class="text-muted">This action cannot be undone. Please confirm the details below.</p>
            </div>

            <div class="card border-0 shadow-sm overflow-hidden">
                <div class="card-header bg-danger text-white py-3">
                    <h5 class="mb-0 text-center">
                        <i class="fas fa-trash-alt me-2"></i> @Model.EventName
                    </h5>
                </div>

                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <tbody>
                            <tr>
                                <th class="bg-light ps-4 w-30" scope="row">Date & Time</th>
                                <td class="ps-3">
                                    <i class="far fa-calendar-alt text-muted me-2"></i>
                                    @Model.EventDate.ToShortDateString() at @Model.EventTime
                                </td>
                            </tr>
                            <tr>
                                <th class="bg-light ps-4" scope="row">Price</th>
                                <td class="ps-3 fw-bold text-success">
                                    @Html.DisplayFor(model => model.Price)
                                </td>
                            </tr>
                            <tr>
                                <th class="bg-light ps-4" scope="row">Category / Venue</th>
                                <td class="ps-3">
                                    <span class="badge bg-secondary">ID: @Model.CategoryID</span> /
                                    <span class="badge bg-dark">ID: @Model.VenueID</span>
                                </td>
                            </tr>
                            <tr>
                                <th class="bg-light ps-4" scope="row">Status</th>
                                <td class="ps-3">
                                    <span class="badge @(Model.AvailabilityStatus == "Active" ? "bg-success" : "bg-warning text-dark")">
                                        @Model.AvailabilityStatus
                                    </span>
                                </td>
                            </tr>
                            <tr>
                                <th class="bg-light ps-4 align-top" scope="row">Description</th>
                                <td class="ps-3 text-muted">
                                    @(string.IsNullOrEmpty(Model.Description) ? "No description provided." : Model.Description)
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="card-footer bg-white border-top-0 p-4">
                    <form asp-action="Delete">
                        <input type="hidden" asp-for="EventID" />
                        <div class="d-grid gap-2 d-md-flex justify-content-md-center">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4 py-2">
                                <i class="fas fa-times me-1"></i> No, Keep It
                            </a>
                            <button type="submit" class="btn btn-danger px-4 py-2 shadow-sm">
                                <i class="fas fa-trash-alt me-1"></i> Yes, Delete Permanentely
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .w-30 { width: 30%; }
    .card { border-radius: 12px; }
    .table th { border-right: 1px solid #dee2e6; }
</style>
