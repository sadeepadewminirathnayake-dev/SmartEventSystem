@model IEnumerable<SmartEventSystem.Models.Event>

@{
    ViewData["Title"] = "Event Management";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

<div class="container-fluid mt-4 px-4">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h2 class="fw-bold text-dark m-0">Event Dashboard</h2>
            <p class="text-muted">Manage your upcoming schedules and event listings.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary shadow-sm px-4 py-2">
            <i class="fas fa-plus-circle me-2"></i>Create New Event
        </a>
    </div>

    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-primary text-white p-3">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="small text-uppercase opacity-75">Total Events</h6>
                        <h3 class="fw-bold mb-0">@Model.Count()</h3>
                    </div>
                    <i class="fas fa-calendar-alt fa-2x opacity-25"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-secondary">
                        <tr>
                            <th class="ps-4">@Html.DisplayNameFor(model => model.EventName)</th>
                            <th>Schedule</th>
                            <th>Price</th>
                            <th>Status</th>
                            <th>Category/Venue</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold text-dark">@item.EventName</div>
                                    <div class="small text-muted text-truncate" style="max-width: 200px;">
                                        @item.Description
                                    </div>
                                </td>
                                <td>
                                    <div class="small fw-bold">@item.EventDate.ToShortDateString()</div>
                                    <div class="small text-muted">@item.EventTime.ToString(@"hh\:mm")</div>
                                </td>
                                <td class="fw-bold text-success">
                                    @item.Price.ToString("C")
                                </td>
                                <td>
                                    <span class="badge rounded-pill @(item.AvailabilityStatus == "Active" ? "bg-success-subtle text-success border border-success" : "bg-warning-subtle text-warning-emphasis border border-warning") px-3">
                                        @item.AvailabilityStatus
                                    </span>
                                </td>
                                <td>
                                    <div class="badge bg-light text-dark border">Cat: @item.CategoryID</div>
                                    <div class="badge bg-light text-dark border">Ven: @item.VenueID</div>
                                </td>
                                <td class="text-center">
                                    <div class="btn-group shadow-sm" role="group">
                                        <a asp-action="Edit" asp-route-id="@item.EventID" class="btn btn-outline-primary btn-sm" title="Edit">
                                            <i class="fas fa-pencil-alt"></i>
                                        </a>
                                        <a asp-action="Details" asp-route-id="@item.EventID" class="btn btn-outline-info btn-sm" title="Details">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.EventID" class="btn btn-outline-danger btn-sm" title="Delete">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #f4f7f6;
    }

    .table thead th {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        padding-top: 15px;
        padding-bottom: 15px;
        border-bottom: 1px solid #eee;
    }

    .table tbody tr {
        transition: all 0.2s;
    }

        .table tbody tr:hover {
            background-color: #fdfdfd;
            transform: scale(1.002);
            box-shadow: inset 4px 0 0 #0d6efd;
        }

    .btn-group .btn {
        padding: 0.4rem 0.8rem;
    }

    .bg-success-subtle {
        background-color: #e1f7ec;
    }

    .bg-warning-subtle {
        background-color: #fff8e6;
    }
</style>