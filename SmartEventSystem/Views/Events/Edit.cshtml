@model SmartEventSystem.Models.Event

@{
    ViewData["Title"] = "Edit Event";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">

            <div class="d-flex align-items-center justify-content-between mb-4">
                <div>
                    <h2 class="fw-bold text-dark"><i class="fas fa-edit text-primary me-2"></i>Edit Event</h2>
                    <p class="text-muted">Modify the details for <strong>@Model.EventName</strong></p>
                </div>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                    <i class="fas fa-undo me-1"></i> Discard Changes
                </a>
            </div>

            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm" role="alert"></div>
                <input type="hidden" asp-for="EventID" />

                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4 p-md-5">

                        <h5 class="text-primary border-bottom pb-2 mb-4">
                            <i class="fas fa-info-circle me-2"></i>Core Information
                        </h5>

                        <div class="row mb-4">
                            <div class="col-md-12 mb-3">
                                <label asp-for="EventName" class="form-label fw-semibold"></label>
                                <input asp-for="EventName" class="form-control form-control-lg" placeholder="Enter event name" />
                                <span asp-validation-for="EventName" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-4">
                                <label asp-for="EventDate" class="form-label fw-semibold"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white"><i class="far fa-calendar-alt"></i></span>
                                    <input asp-for="EventDate" class="form-control" type="date" />
                                </div>
                                <span asp-validation-for="EventDate" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="EventTime" class="form-label fw-semibold"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white"><i class="far fa-clock"></i></span>
                                    <input asp-for="EventTime" class="form-control" type="time" />
                                </div>
                                <span asp-validation-for="EventTime" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Price" class="form-label fw-semibold"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light fw-bold">$</span>
                                    <input asp-for="Price" class="form-control" placeholder="0.00" />
                                </div>
                                <span asp-validation-for="Price" class="text-danger small"></span>
                            </div>
                        </div>

                        <h5 class="text-primary border-bottom pb-2 mt-5 mb-4">
                            <i class="fas fa-map-marked-alt me-2"></i>Logistics & Logistics
                        </h5>

                        <div class="row mb-4">
                            <div class="col-md-4">
                                <label asp-for="CategoryID" class="form-label fw-semibold">Category ID</label>
                                <input asp-for="CategoryID" class="form-control bg-light" />
                                <span asp-validation-for="CategoryID" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="VenueID" class="form-label fw-semibold">Venue ID</label>
                                <input asp-for="VenueID" class="form-control bg-light" />
                                <span asp-validation-for="VenueID" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="AvailabilityStatus" class="form-label fw-semibold">Status</label>
                                <select asp-for="AvailabilityStatus" class="form-select border-primary shadow-sm">
                                    <option value="Active">Active</option>
                                    <option value="Inactive">Inactive</option>
                                    <option value="Draft">Draft</option>
                                </select>
                                <span asp-validation-for="AvailabilityStatus" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label fw-semibold"></label>
                            <textarea asp-for="Description" class="form-control" rows="4" placeholder="Update the event description..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-5">
                            <a asp-action="Index" class="btn btn-light px-4">Cancel</a>
                            <button type="submit" class="btn btn-primary px-5 shadow">
                                <i class="fas fa-save me-2"></i>Update Event
                            </button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #f8f9fa;
    }

    .card {
        border-radius: 15px;
    }

    .form-control:focus, .form-select:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.1);
    }

    .form-label {
        color: #495057;
    }

    .input-group-text {
        border-right: none;
        color: #6c757d;
    }

    .input-group .form-control {
        border-left: none;
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}