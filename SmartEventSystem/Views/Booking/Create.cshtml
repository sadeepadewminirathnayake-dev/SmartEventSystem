@model SmartEventSystem.Models.Booking

<div class="container mt-5">

    <div class="card shadow-lg border-0 rounded-4 booking-card">

        <div class="card-body p-5">

            <h2 class="text-center text-success fw-bold mb-4">
                🎟 Book Your Ticket
            </h2>

            @if (TempData["PaymentSuccess"] != null)
            {
                <div class="alert alert-success">
                    @TempData["PaymentSuccess"]
                </div>
            }

            <form asp-action="Create" method="post">

                <input type="hidden" asp-for="EventID" />

                <!-- Seat Type -->
                <div class="mb-4">
                    <label class="form-label fw-bold">Select Seat Type</label>
                    <select asp-for="SeatType" class="form-select">
                        <option value="Regular">Regular (Rs. 2500)</option>
                        <option value="Balcony">Balcony (Rs. 3000)</option>
                        <option value="Premium">Premium (Rs. 3500)</option>
                        <option value="VIP">VIP (Rs. 5000)</option>
                        <option value="Front Row">Front Row (Rs. 6000)</option>
                        <option value="VVIP">VVIP (Rs. 8000)</option>
                    </select>
                </div>

                <!-- Quantity -->
                <div class="mb-4">
                    <label class="form-label fw-bold">Quantity</label>
                    <input asp-for="Quantity"
                           type="number"
                           min="1"
                           class="form-control"
                           placeholder="Enter number of tickets" />
                </div>

                <!-- Button -->
                <div class="d-grid">
                    <button type="submit" class="btn btn-success btn-lg">
                        Confirm Booking
                    </button>
                </div>

            </form>

        </div>

    </div>

</div>

<style>
    .booking-card {
        max-width: 600px;
        margin: auto;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .booking-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.2);
        }

    .btn-success {
        border-radius: 10px;
    }

    .form-control, .form-select {
        border-radius: 8px;
    }
</style>


