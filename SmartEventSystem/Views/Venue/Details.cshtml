@model SmartEventSystem.Models.Venue

<h2>Venue Details</h2>

<table class="table table-bordered">
    <tr>
        <th>Venue Name</th>
        <td>@Model.VenueName</td>
    </tr>
    <tr>
        <th>Address</th>
        <td>@Model.Address</td>
    </tr>
    <tr>
        <th>City</th>
        <td>@Model.City</td>
    </tr>
    <tr>
        <th>Capacity</th>
        <td>@Model.Capacity</td>
    </tr>
    <tr>
        <th>Description</th>
        <td>@Model.Description</td>
    </tr>
</table>

<a asp-controller="Event"
   asp-action="Browse"
   class="btn btn-secondary">
    Back to Events
</a>

