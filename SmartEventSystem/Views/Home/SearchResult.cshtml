@model List<SmartEventSystem.Models.Event>

<div class="container mt-5">

    <h2 class="text-center fw-bold text-primary mb-4">
        Search Results
    </h2>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-warning text-center shadow-sm">
            <h5>No events found.</h5>
            <p class="mb-0">Try searching with a different event name.</p>
        </div>
    }
    else
    {
        <div class="row">

            @foreach (var item in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card shadow border-0 rounded-4 h-100 search-card">

                        <div class="card-body">

                            <h5 class="card-title text-dark fw-bold">
                                @item.EventName
                            </h5>

                            <p class="mb-2">
                                <strong>Date:</strong>
                                @item.EventDate.ToShortDateString()
                            </p>

                            <p class="mb-3">
                                <strong>Price:</strong>
                                <span class="badge bg-success fs-6">
                                    Rs. @item.Price
                                </span>
                            </p>

                            <div class="d-grid">
                                <a asp-controller="Event"
                                   asp-action="Details"
                                   asp-route-id="@item.EventID"
                                   class="btn btn-primary">
                                    View Details
                                </a>
                            </div>

                        </div>

                    </div>
                </div>
            }

        </div>
    }

</div>

<style>
    .search-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .search-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 12px 25px rgba(0,0,0,0.15);
        }
</style>
