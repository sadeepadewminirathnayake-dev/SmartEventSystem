@model List<SmartEventSystem.Models.Event>

<div class="container mt-5">

    <h2 class="text-center text-primary fw-bold mb-4">
        Search Results
    </h2>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-warning text-center">
            No events found.
        </div>
    }
    else
    {
        <div class="row">

            @foreach (var item in Model)
            {
                <div class="col-md-6 mb-4">
                    <div class="card shadow border-0 rounded-4 h-100">

                        <div class="card-body">

                            <h5 class="fw-bold text-dark">
                                @item.EventName
                            </h5>

                            <p>
                                <strong>Date:</strong>
                                @item.EventDate.ToShortDateString()
                            </p>

                            <p>
                                <strong>Price:</strong>
                                <span class="badge bg-success">
                                    Rs. @item.Price
                                </span>
                            </p>

                            <!-- 🔹 Availability Badge -->
                            <p class="mt-2">
                                <strong>Status:</strong>
                                <span class="badge @(item.AvailabilityStatus == "Available" ? "bg-success" : "bg-danger")">
                                    @item.AvailabilityStatus
                                </span>
                            </p>

                        </div>

                        <div class="card-footer bg-white border-0">

                            <a asp-controller="Event"
                               asp-action="Details"
                               asp-route-id="@item.EventID"
                               class="btn btn-primary w-100 mb-2">
                                View Details
                            </a>

                            <a asp-controller="Venue"
                               asp-action="Details"
                               asp-route-id="@item.VenueID"
                               class="btn btn-outline-info w-100 mb-2">
                                View Venue
                            </a>

                            <!-- 🔒 Guest Restriction -->
                            @if (Context.Session.GetString("UserEmail") == null)
                            {
                                <a asp-controller="Account"
                                   asp-action="Login"
                                   class="btn btn-warning w-100">
                                    Login to Book
                                </a>
                            }

                        </div>

                    </div>
                </div>
            }

        </div>
    }

</div>

